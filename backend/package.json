{
  "name": "typeahead-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend for the search typeahead system: Express + TypeScript API, consistent-hash-routed Redis cache, Postgres primary store, batch writes, recency ranking.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "dataset": "tsx ../scripts/generate-dataset.ts",
    "ingest": "tsx ../scripts/ingest.ts",
    "bench": "tsx ../scripts/bench.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
