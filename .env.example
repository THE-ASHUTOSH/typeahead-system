# Example environment for the search typeahead backend.
# Copy to `.env` (cp .env.example .env) — config.ts loads it via dotenv.
# Every value here is also the built-in default in config.ts, so an empty .env still works.

# Port the Express API listens on (the React UI on :5173 calls it).
PORT=8080

# Postgres connection (matches the docker-compose credentials: user/pass/db = typeahead).
DATABASE_URL=postgres://typeahead:typeahead@localhost:5432/typeahead

# The three logical Redis cache nodes our consistent-hash ring routes prefixes across.
# Format: host:port,host:port,... (these map to redis-0/redis-1/redis-2 in docker-compose).
REDIS_NODES=localhost:6379,localhost:6380,localhost:6381

# Seconds a cached prefix result lives before expiring (staleness bound for suggestions).
CACHE_TTL_SECONDS=60

# Virtual nodes per physical Redis node on the ring (higher = more even key distribution).
RING_VIRTUAL_NODES=150

# Max suggestions returned by /suggest (the spec caps this at 10).
SUGGEST_LIMIT=10

# Flush the batch buffer once it holds this many distinct aggregated queries.
BATCH_SIZE=500

# Flush the batch buffer at least this often in milliseconds, even if it is not full.
BATCH_FLUSH_MS=2000

# Recency-ranking weights — score = W_1H*count_1h + W_24H*count_24h + W_ALLTIME*all_time_count.
# Last hour weighted highest so a current burst can out-rank an all-time favourite (= trending).
W_1H=3
# Last 24h smooths single-hour noise without dominating the 1h term.
W_24H=1.5
# All-time count is the popularity baseline / score floor for queries with no recent activity.
W_ALLTIME=1.0
